# Copy to .env.local and fill in your environment values before running start_combined.sh

# --- MySQL Database ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=llm_ua_clinical
DB_USER=your_mysql_username
DB_PASSWORD=your_mysql_password

# --- FastAPI Backend ---
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# --- Generative AI Frontend ---
NEXT_PUBLIC_LLM_API_BASE=http://localhost:8000

# --- Elasticsearch ---
# Set this to the directory that contains bin/elasticsearch (no trailing slash)
ELASTICSEARCH_HOME=/path/to/elasticsearch
# Use HTTPS with self-signed cert by default; adjust as required
ELASTICSEARCH_URL=https://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=P@ssw0rd

# --- Misc ---
NODE_ENV=development
