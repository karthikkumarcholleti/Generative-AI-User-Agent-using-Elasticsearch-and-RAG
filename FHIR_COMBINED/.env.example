# FHIR LLM Clinical Dashboard - Configuration Template
# Copy this file to .env and edit with your values
# DO NOT commit .env to git (it contains secrets)

# ============================================================================
# PORT CONFIGURATION
# ============================================================================
BACKEND_PORT=8001
FRONTEND_PORT=3000
ELASTICSEARCH_PORT=9200

# ============================================================================
# SERVICE URLs (for remote services)
# ============================================================================
BACKEND_URL=http://localhost:8001
FRONTEND_URL=http://localhost:3000
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_URL=http://localhost:9200

# ============================================================================
# ELASTICSEARCH CONFIGURATION
# ============================================================================
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=CHANGE_ME

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=llm_ua_clinical
DB_USER=CHANGE_ME
DB_PASSWORD=CHANGE_ME

# ============================================================================
# LLM MODEL CONFIGURATION
# ============================================================================
# Model path (relative to project root or absolute path)
LLM_MODEL_PATH=./FHIR_LLM_UA/models/llama31-8b-bnb4
LLM_MAX_NEW_TOKENS=800
LLM_TEMPERATURE=0.3
LLM_TOP_P=0.9
LLM_MAX_CONDITIONS=50
LLM_MAX_OBSERVATIONS=100
LLM_MAX_NOTES=3
LLM_MAX_NOTE_CHARS=2500
